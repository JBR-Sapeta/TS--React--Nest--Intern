{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "dev": " cross-env NODE_ENV=dev nest start --watch",
    "start": "cross-env NODE_ENV=prod  node dist/main",
    "test": "cross-env NODE_ENV=test jest --watchAll=false",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:cov": "cross-env NODE_ENV=test jest --coverage",
    "test:e2e": "cross-env NODE_ENV=test jest  --maxWorkers=1 --config ./jest-e2e.json",
    "test:e2e:cov": "cross-env NODE_ENV=test jest --coverage --maxWorkers=1 --config ./jest-e2e.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint-commit": "lint-staged"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.569.0",
    "@nestjs-modules/ioredis": "2.0.2",
    "@nestjs-modules/mailer": "1.10.3",
    "@nestjs/common": "10.0.0",
    "@nestjs/config": "3.2.0",
    "@nestjs/core": "10.0.0",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/passport": "10.0.3",
    "@nestjs/platform-express": "10.0.0",
    "@nestjs/schedule": "4.0.2",
    "@nestjs/swagger": "7.3.0",
    "@nestjs/typeorm": "10.0.2",
    "bcrypt": "5.1.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "cross-env": "7.0.3",
    "ejs": "3.1.9",
    "helmet": "^7.1.0",
    "ioredis": "5.3.2",
    "multer": "1.4.5-lts.1",
    "nest-winston": "1.9.4",
    "nodemailer": "6.9.9",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "passport-local": "1.0.0",
    "pg": "8.11.3",
    "ramda": "0.29.1",
    "reflect-metadata": "0.2.0",
    "rxjs": "7.8.1",
    "typeorm": "0.3.20",
    "typeorm-naming-strategies": "4.1.0",
    "uuid": "9.0.1",
    "winston": "3.11.0"
  },
  "devDependencies": {
    "@nestjs/cli": "10.0.0",
    "@nestjs/schematics": "10.0.0",
    "@nestjs/testing": "10.0.0",
    "@types/bcrypt": "5.0.2",
    "@types/express": "4.17.17",
    "@types/jest": "29.5.2",
    "@types/multer": "1.4.11",
    "@types/node": "20.3.1",
    "@types/passport-jwt": "4.0.1",
    "@types/passport-local": "1.0.38",
    "@types/ramda": "0.29.10",
    "@types/supertest": "6.0.0",
    "@types/uuid": "9.0.8",
    "@typescript-eslint/eslint-plugin": "6.0.0",
    "@typescript-eslint/parser": "6.0.0",
    "eslint": "8.42.0",
    "eslint-config-prettier": "9.0.0",
    "eslint-plugin-prettier": "5.0.0",
    "jest": "29.5.0",
    "lint-staged": "15.2.2",
    "prettier": "3.0.0",
    "source-map-support": "0.5.21",
    "supertest": "6.3.3",
    "ts-jest": "29.1.0",
    "ts-loader": "9.4.3",
    "ts-node": "10.9.1",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "verbose": true
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --quiet --fix"
    ],
    "*.{json,md,js,ts}": [
      "prettier --write"
    ]
  }
}
